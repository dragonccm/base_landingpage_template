{
  "version": 1,
  "autoflow": {
    "defaultMaxLoops": 2,
    "defaultRetries": {
      "intake": 1,
      "plan": 1,
      "build": 1,
      "test": 1,
      "security": 1,
      "release": 0
    },
    "failureKeywords": {
      "runtime_error": ["[live_error]"],
      "security_gate": ["critical", "security"],
      "test_gate": ["test", "assert", "spec"],
      "build_gate": ["build", "compile"],
      "quality_gate": ["fail", "failed", "blocker"]
    },
    "requireStructuredGate": true,
    "releaseVerifyCommand": "npm run verify:release",
    "releaseVerifyTemplatePath": "../nextcms"
  }
}
