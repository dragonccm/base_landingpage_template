# Telegram bot token from BotFather
TELEGRAM_BOT_TOKEN=

# Comma-separated allowlists (optional but recommended)
TELEGRAM_ALLOW_USER_IDS=
TELEGRAM_ALLOW_CHAT_IDS=

# 0 = dry-run (default), 1 = live mode via `openclaw agent --json`
OPENCLAW_LIVE_MODE=0

# Optional: map roles to configured OpenClaw agent IDs
OPENCLAW_AGENT_DEFAULT=main
# OPENCLAW_AGENT_SUBAGENT_REQUIREMENTS=requirements
# OPENCLAW_AGENT_SUBAGENT_PLANNER=planner
# OPENCLAW_AGENT_ACP_DEVELOPER=developer
# OPENCLAW_AGENT_ACP_TESTER=tester
# OPENCLAW_AGENT_ACP_DEBUGGER=debugger
